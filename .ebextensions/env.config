option_settings:
  aws:elasticbeanstalk:application:environment:
    OPENAI_API_KEY: "your-openai-api-key-here"  # Replace with your actual OpenAI API key
    HOST: "0.0.0.0"
    PORT: "5000"
    APP_DEBUG: "false"
    DATABASE_PATH: "/var/app/current/app/data/devsecops.db"
    LOG_PATH: "/var/app/current/app/app.log"
    SCAN_ROOT: "/var/app/current"
    MAX_SCAN_LENGTH: "100000"
    SCAN_RESULT_LIMIT: "25"
    LOGIN_ATTEMPT_LIMIT: "5"
    LOGIN_WINDOW_SECONDS: "60"
    DEMO_USERNAME: "security-admin"
    DEMO_PASSWORD: "change-this-password"  # Set a secure password
    OPENAI_MODEL: "gpt-4o-mini"